layout {
    default_tab_template {
        pane size=1 split_direction="vertical" {
            pane size=55 borderless=true {
                plugin location="tab-bar" {
                    hide_session_name true
                }
            }

            pane borderless=true {
                plugin location="status-bar"
            }
        }
        children
    }

    tab name="1 Editor" borderless=true focus=true {
        pane borderless=true command="nvim"
    }

    tab name="2 Run" split_direction="horizontal" {
        pane cwd="" command="clear" start_suspended=true
    }
}
